{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "audiogram",
  "version": "0.1.1",
  "identifier": "com.eg.audiogram",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:free",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "audiogram",
        "decorations": false,
        "width": 800,
        "height": 600
      }
    ],
    "security": {
       "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$APPDATA/**", "$DATA/**", "**"],
          "deny": []
        }
      },
      "csp": null
    }
  },
  "plugins":{
    "updater": {
    "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIxNjgwQUI5QjM2MjQ4NDQKUldSRVNHS3p1UXBvc1hCR3E1dys2eHF0dHVtNElVdEZaT2JUWmhVZjg3OE0yVC9tbUZpSXUwaU0K",
    "endpoints": [
      "https://eg0r0k.github.io/AudioGram/manifests/stable/latest.json"
    ],
    "windows": {
      "installMode": "passive"
    }
  }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["mp3"],
        "name": "MP3 Audio",
        "description": "MP3 Audio File - Audiogram",
        "mimeType": "audio/mpeg",
        "role": "Editor",
        "rank": "Default"
      },
      {
        "ext": ["wav"],
        "name": "WAV Audio",
        "description": "WAV Audio File - Audiogram",
        "mimeType": "audio/wav",
        "role": "Editor",
        "rank": "Default"
      },
      {
        "ext": ["flac"],
        "name": "FLAC Audio",
        "description": "FLAC Lossless Audio - Audiogram",
        "mimeType": "audio/flac",
        "role": "Editor",
        "rank": "Default"
      },
      {
        "ext": ["ogg"],
        "name": "OGG Audio",
        "description": "OGG Vorbis Audio - Audiogram",
        "mimeType": "audio/ogg",
        "role": "Editor",
        "rank": "Default"
      },
      {
        "ext": ["m4a", "aac"],
        "name": "AAC Audio",
        "description": "AAC Audio File - Audiogram",
        "mimeType": "audio/aac",
        "role": "Editor",
        "rank": "Default"
      },
      {
        "ext": ["wma"],
        "name": "WMA Audio",
        "description": "Windows Media Audio - Audiogram",
        "mimeType": "audio/x-ms-wma",
        "role": "Editor",
        "rank": "Default"
      }
    ]
  }
}
